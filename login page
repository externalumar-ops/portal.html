app.get("/", (req, res) => {
  res.send(`
<!DOCTYPE html>
<html>
<head>
  <title>XOUNNET</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: linear-gradient(120deg, #0f2027, #203a43, #2c5364);
      color: white;
      text-align: center;
    }

    .container {
      padding: 20px;
      max-width: 500px;
      margin: auto;
    }

    .card {
      background: rgba(255,255,255,0.08);
      padding: 15px;
      margin: 15px 0;
      border-radius: 12px;
    }

    h1 {
      margin-top: 20px;
    }

    button {
      width: 100%;
      padding: 12px;
      margin: 6px 0;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      background: #00c853;
      color: white;
    }

    .plan {
      background: #ff9800;
    }

    input {
      width: 90%;
      padding: 12px;
      margin: 8px 0;
      border-radius: 8px;
      border: none;
      text-align: center;
    }

    .hidden {
      display: none;
    }

    .title {
      font-size: 22px;
      font-weight: bold;
    }

    .small {
      font-size: 13px;
      opacity: 0.8;
    }
  </style>
</head>

<body>

<div class="container">

  <h1>XOUNNET</h1>
  <div class="small">Built for connection</div>

  <!-- STEP 1: SELECT PACKAGE -->
  <div class="card" id="step1">
    <div class="title">Select Package</div>

    <button class="plan" onclick="selectPlan(500,'3 Hours')">3 Hours - UGX 500</button>
    <button class="plan" onclick="selectPlan(1000,'24 Hours')">24 Hours - UGX 1000</button>
    <button class="plan" onclick="selectPlan(2500,'3 Days')">3 Days - UGX 2500</button>
    <button class="plan" onclick="selectPlan(4000,'7 Days')">7 Days - UGX 4000</button>
  </div>

  <!-- STEP 2: PAYMENT INFO -->
  <div class="card hidden" id="step2">
    <div class="title">Payment Instructions</div>

    <p>Send money via:</p>
    <p><b>Airtel / MTN Mobile Money</b></p>
    <p>Merchant Code: <b>4404970</b></p>

    <p>Selected Package:</p>
    <p id="selectedPlan"></p>

    <input id="phone" placeholder="Phone number used to pay">

    <button onclick="submitPayment()">Confirm Payment</button>
  </div>

  <!-- STEP 3: VOUCHER -->
  <div class="card hidden" id="step3">
    <div class="title">Your Voucher</div>

    <p id="voucherBox">Waiting...</p>

    <input id="voucherInput" placeholder="Enter Voucher Code">

    <button onclick="redeem()">Connect</button>
  </div>

  <p id="msg"></p>

</div>

<script>
let selectedAmount = 0;
let selectedName = "";

const API = window.location.origin;

function selectPlan(amount, name){
  selectedAmount = amount;
  selectedName = name;

  document.getElementById("step1").classList.add("hidden");
  document.getElementById("step2").classList.remove("hidden");

  document.getElementById("selectedPlan").innerText =
    name + " - UGX " + amount;
}

// STEP 2 → send payment info
function submitPayment(){

  fetch(API + "/create", {
    method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({
      amount: selectedAmount,
      phone: document.getElementById("phone").value
    })
  })
  .then(r => r.json())
  .then(d => {

    document.getElementById("step2").classList.add("hidden");
    document.getElementById("step3").classList.remove("hidden");

    document.getElementById("voucherBox").innerText = d.code;

    msg.innerText = "Payment received. Voucher generated.";
  });
}

// STEP 3 → redeem
function redeem(){
  fetch(API + "/redeem", {
    method: "POST",
    headers: {"Content-Type":"application/json"},
    body: JSON.stringify({
      code: voucherInput.value
    })
  })
  .then(r => r.json())
  .then(d => {
    msg.innerText = d.message;
  });
}

</script>

